# GHL
GHL_API_KEY=                    # GHL private integration API key
GHL_LOCATION_ID=                # GHL location/sub-account ID
GHL_WEBHOOK_SECRET=             # Shared secret for GHL webhook verification
GHL_CALENDAR_ID=                # GHL calendar ID for appointment booking

# Notion
NOTION_TOKEN=                   # Notion integration token
NOTION_LEADS_DB_ID=             # Notion leads database ID

# Calendar
CALENDAR_SECRET=                # Random secret for iCal feed URL

# Database
DATABASE_URL=                   # PostgreSQL connection string (postgresql+asyncpg://...)

# Clerk Auth
CLERK_PUBLISHABLE_KEY=          # From Clerk dashboard → API Keys
CLERK_SECRET_KEY=               # From Clerk dashboard → API Keys

# Notion → GHL Sync
NOTION_GHL_SYNC_ENABLED=true    # Master on/off switch
NOTION_GHL_SYNC_DRY_RUN=true   # Log-only mode (no GHL writes)
NOTION_GHL_SYNC_AFTER_DATE=2026-03-03  # Only sync appointments >= this date
NOTION_GHL_SYNC_INTERVAL=300   # Seconds between polls (default 5 min)

# Plaid (Phase 2)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox               # sandbox | development | production
